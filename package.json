{
  "name": "@lehnihon/bit-form",
  "version": "2.2.18",
  "description": "Gerenciamento de estado de formulários agnóstico e performático",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lehnihon/bit-form.git"
  },
  "homepage": "https://github.com/lehnihon/bit-form#readme",
  "bugs": {
    "url": "https://github.com/lehnihon/bit-form/issues"
  },
  "keywords": [
    "form",
    "validation",
    "react",
    "vue",
    "angular",
    "react-native",
    "form-state",
    "form-validation",
    "mask",
    "framework-agnostic"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "bit-form": "./dist/cli/index.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./core/store": {
      "types": "./dist/core/store.d.ts",
      "import": "./dist/core/store.js",
      "require": "./dist/core/store.cjs"
    },
    "./core/bindings": {
      "types": "./dist/core/bindings.d.ts",
      "import": "./dist/core/bindings.js",
      "require": "./dist/core/bindings.cjs"
    },
    "./core/status": {
      "types": "./dist/core/status.d.ts",
      "import": "./dist/core/status.js",
      "require": "./dist/core/status.cjs"
    },
    "./core/utils": {
      "types": "./dist/core/utils.d.ts",
      "import": "./dist/core/utils.js",
      "require": "./dist/core/utils.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./react-native": {
      "types": "./dist/react-native/index.d.ts",
      "import": "./dist/react-native/index.js",
      "require": "./dist/react-native/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./angular": {
      "types": "./dist/angular/index.d.ts",
      "import": "./dist/angular/index.js",
      "require": "./dist/angular/index.cjs"
    },
    "./mask": {
      "types": "./dist/mask.d.ts",
      "import": "./dist/mask.js",
      "require": "./dist/mask.cjs"
    },
    "./resolvers/*": {
      "types": "./dist/resolvers/*.d.ts",
      "import": "./dist/resolvers/*.js",
      "require": "./dist/resolvers/*.cjs"
    },
    "./resolvers": {
      "types": "./dist/resolvers/index.d.ts",
      "import": "./dist/resolvers/index.js",
      "require": "./dist/resolvers/index.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js",
      "require": "./dist/devtools/index.cjs"
    },
    "./devtools/bridge": {
      "types": "./dist/devtools/bridge.d.ts",
      "import": "./dist/devtools/bridge.js",
      "require": "./dist/devtools/bridge.cjs"
    },
    "./devtools/protocol": {
      "types": "./dist/devtools/protocol.d.ts",
      "import": "./dist/devtools/protocol.js",
      "require": "./dist/devtools/protocol.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "sync": "npm run build && yalc push",
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "npm run test:all",
    "test:all": "vitest run",
    "test:unit": "vitest run src/tests/core src/tests/devtools src/tests/resolvers",
    "test:frameworks": "vitest run src/tests/frameworks",
    "test:integration": "vitest run src/tests/integration",
    "test:cli": "vitest run src/tests/cli",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest run -c quality/vitest.quality.config.ts quality/bench/perf.test.ts",
    "test:bench:memory": "vitest run -c quality/vitest.quality.config.ts quality/bench/memory.bench.ts",
    "test:bench:compare": "vitest run -c quality/vitest.quality.config.ts quality/bench/rhf-compare.test.ts --maxWorkers=1 --minWorkers=1",
    "test:bench:all": "npm run test:bench && npm run test:bench:memory && npm run test:bench:compare",
    "test:quality:critical": "npm run test:bench && npm run test:bench:memory && npm run test:release-gates",
    "test:compat": "node quality/compat/run-compat.mjs",
    "test:observability": "vitest run -c quality/vitest.quality.config.ts quality/release-gates/observability.test.ts",
    "test:bundle-size": "vitest run -c quality/vitest.quality.config.ts quality/release-gates/bundle-size.test.ts",
    "test:release-gates": "npm run build && npm run test:bench && npm run test:bench:memory && npm run test:bundle-size && vitest run -c quality/vitest.quality.config.ts quality/release-gates/bundle-size-gate.test.ts && npm run test:observability",
    "clean": "rm -rf dist && rm -f *.tsbuildinfo",
    "lint": "npm run lint:eslint && npm run lint:types",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:eslint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "lint:types": "npm run clean && tsc --build && tsc -p tsconfig.test.json",
    "lint:imports": "npm run lint:eslint:fix",
    "prepublishOnly": "npm run build",
    "release": "npm publish",
    "dry-run": "npm publish --dry-run",
    "bundle-ctx": "repomix",
    "setup-hooks": "sh scripts/setup-hooks.sh"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0",
    "joi": "^17.0.0",
    "react": ">=16.8.0",
    "vue": ">=3.0.0",
    "yup": "^1.0.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "joi": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/common": "^21.1.3",
    "@angular/compiler": "^21.1.3",
    "@angular/core": "^21.1.3",
    "@angular/platform-browser": "^21.1.3",
    "@angular/platform-browser-dynamic": "^21.1.3",
    "@eslint/js": "^10.0.1",
    "@tanstack/react-form": "^1.28.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.19.11",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/react-native": "^0.72.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "formik": "^2.4.9",
    "joi": "^17.13.3",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.62.0",
    "repomix": "^1.11.1",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.6",
    "typescript": "^5.9.3",
    "vite": "^5.4.19",
    "vitest": "^3.0.5",
    "vue": "^3.5.13",
    "yup": "^1.7.1",
    "zod": "^3.25.7",
    "zone.js": "^0.16.0"
  }
}